NEXT_PUBLIC_TRANXIT_API_URL=http://localhost:61260
TRANXIT_API_URL=http://localhost:61260
TRANXIT_DEPLOY_ENV=development

# Demo auth and dev OTP surfacing are intentionally opt-in for tests/local work.
TRANXIT_ENABLE_DEMO_AUTH=false
TRANXIT_E2E_EXPOSE_DEV_CODE=false

# Optional staging E2E OTP source. Leave unset locally to use the dev OTP cookie.
TRANXIT_E2E_MAIL_INBOX=
TRANXIT_E2E_MAIL_INBOX_USER=
TRANXIT_E2E_MAIL_INBOX_PASSWORD=
